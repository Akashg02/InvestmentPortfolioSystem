@page "/clients/{ClientId:guid}"
@attribute [Authorize]
@inject IApiService ApiService
@inject NavigationManager Navigation

<PageTitle>@(_client?.FullName ?? "Client") - Investment Portfolio</PageTitle>

@if (_isLoading)
{
    <div class="d-flex justify-content-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (_client is null)
{
    <div class="alert alert-danger">Client not found.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/clients">Clients</a></li>
                    <li class="breadcrumb-item active">@_client.FullName</li>
                </ol>
            </nav>
            <h1>@_client.FullName</h1>
        </div>
        <button class="btn btn-primary" @onclick="() => _showAddPortfolio = true">+ New Portfolio</button>
    </div>

    <!-- Client Info -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Contact Info</h6>
                    <p class="mb-1"><strong>Email:</strong> @_client.Email</p>
                    <p class="mb-1"><strong>Phone:</strong> @_client.Phone</p>
                    <p class="mb-1"><strong>Address:</strong> @_client.Address</p>
                    <p class="mb-0"><strong>DOB:</strong> @_client.DateOfBirth.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body">
                            <p class="text-muted small mb-1">Risk Profile</p>
                            <span class="badge fs-6 @GetRiskBadgeClass(_client.RiskProfile)">@_client.RiskProfile</span>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body">
                            <p class="text-muted small mb-1">Total AUM</p>
                            <h5>$@_client.TotalPortfolioValue.ToString("N0")</h5>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body">
                            <p class="text-muted small mb-1">Total Gain/Loss</p>
                            <h5 class="@(_client.TotalGainLoss >= 0 ? "text-success" : "text-danger")">
                                @(_client.TotalGainLoss >= 0 ? "+" : "")$@_client.TotalGainLoss.ToString("N0")
                            </h5>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center">
                        <div class="card-body">
                            <p class="text-muted small mb-1">Return</p>
                            <h5 class="@(_client.TotalGainLossPercent >= 0 ? "text-success" : "text-danger")">
                                @(_client.TotalGainLossPercent >= 0 ? "+" : "")@_client.TotalGainLossPercent.ToString("F2")%
                            </h5>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Portfolios -->
    <h4 class="mb-3">Portfolios (@_portfolios.Count())</h4>
    @if (!_portfolios.Any())
    {
        <div class="alert alert-info">No portfolios yet. Create one to start tracking investments.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var portfolio in _portfolios)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white d-flex justify-content-between">
                            <h6 class="mb-0">@portfolio.Name</h6>
                            <span class="badge @(portfolio.Status == PortfolioStatus.Active ? "bg-success" : "bg-secondary")">
                                @portfolio.Status
                            </span>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-4">
                                    <p class="text-muted small mb-0">Value</p>
                                    <strong>$@portfolio.TotalValue.ToString("N0")</strong>
                                </div>
                                <div class="col-4">
                                    <p class="text-muted small mb-0">Gain/Loss</p>
                                    <strong class="@(portfolio.TotalGainLoss >= 0 ? "text-success" : "text-danger")">
                                        @(portfolio.TotalGainLoss >= 0 ? "+" : "")$@portfolio.TotalGainLoss.ToString("N0")
                                    </strong>
                                </div>
                                <div class="col-4">
                                    <p class="text-muted small mb-0">Return</p>
                                    <strong class="@(portfolio.TotalGainLossPercent >= 0 ? "text-success" : "text-danger")">
                                        @(portfolio.TotalGainLossPercent >= 0 ? "+" : "")@portfolio.TotalGainLossPercent.ToString("F2")%
                                    </strong>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <a href="/portfolios/@portfolio.Id" class="btn btn-outline-primary btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<!-- Add Portfolio Modal -->
@if (_showAddPortfolio)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Portfolio</h5>
                    <button class="btn-close" @onclick="() => _showAddPortfolio = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@_newPortfolio" OnValidSubmit="CreatePortfolioAsync">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">Portfolio Name</label>
                            <InputText class="form-control" @bind-Value="_newPortfolio.Name" placeholder="e.g. Growth Portfolio" />
                            <ValidationMessage For="@(() => _newPortfolio.Name)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="_newPortfolio.Description" rows="3" />
                        </div>
                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-secondary" @onclick="() => _showAddPortfolio = false">Cancel</button>
                            <button type="submit" class="btn btn-primary">Create</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ClientId { get; set; }

    private ClientDto? _client;
    private IEnumerable<PortfolioDto> _portfolios = Enumerable.Empty<PortfolioDto>();
    private CreatePortfolioRequest _newPortfolio = new();
    private bool _isLoading = true;
    private bool _showAddPortfolio;

    protected override async Task OnInitializedAsync()
    {
        var clientTask = ApiService.GetClientAsync(ClientId);
        var portfoliosTask = ApiService.GetPortfoliosByClientAsync(ClientId);
        await Task.WhenAll(clientTask, portfoliosTask);

        var clientResult = clientTask.Result;
        if (clientResult.Success) _client = clientResult.Data;

        var portfolioResult = portfoliosTask.Result;
        if (portfolioResult.Success) _portfolios = portfolioResult.Data ?? Enumerable.Empty<PortfolioDto>();

        _newPortfolio.ClientId = ClientId;
        _isLoading = false;
    }

    private async Task CreatePortfolioAsync()
    {
        var result = await ApiService.CreatePortfolioAsync(_newPortfolio);
        if (result.Success)
        {
            _showAddPortfolio = false;
            _newPortfolio = new() { ClientId = ClientId };
            var refreshResult = await ApiService.GetPortfoliosByClientAsync(ClientId);
            if (refreshResult.Success) _portfolios = refreshResult.Data ?? _portfolios;
        }
    }

    private static string GetRiskBadgeClass(RiskLevel risk) => risk switch
    {
        RiskLevel.Conservative => "bg-success",
        RiskLevel.Moderate => "bg-info",
        RiskLevel.Aggressive => "bg-warning text-dark",
        RiskLevel.VeryAggressive => "bg-danger",
        _ => "bg-secondary"
    };
}
